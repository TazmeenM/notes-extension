{
    "manifest_version": 3,
    "name": "Notes Extension",
    "description": "An extension that allows users to store notes about a webpage",
    "version": "1.0.0",
    "permissions":[
        "sidePanel"
    ],
    "side_panel": {
        "default_path": "index.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}